# --- Meta / Graph API ---
FB_APP_ID=
FB_APP_SECRET=
FB_ACCESS_TOKEN=
GRAPH_API_VERSION=v25.0

# --- Postgres ---
POSTGRES_USER=osint
POSTGRES_PASSWORD=osint
POSTGRES_DB=osint_monitor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://osint:osint@postgres:5432/osint_monitor

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO ---
MINIO_ROOT_USER=osint_admin
MINIO_ROOT_PASSWORD=osint_admin_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=osint-media
MINIO_SECURE=false

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_LLM_MODEL=qwen2.5
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Scheduler ---
POLL_DEFAULT_INTERVAL=300

# --- App ---
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=development
